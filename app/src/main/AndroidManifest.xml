<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JoestarApp">

        <!-- Jeu labyrinthe : forcé en paysage -->
        <activity
            android:name=".labyrinthe.view.JeuLabyrintheActivity"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.FullScreen"
            android:exported="false" />

        <!-- Menu labyrinthe : portrait -->
        <activity
            android:name=".LabyrintheActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <!-- Autres activities : inchangées -->
        <activity
            android:name=".CompteurActivity"
            android:exported="false" />

        <activity
            android:name=".ChronometreActivity"
            android:exported="false" />

        <!-- Activity principale -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
