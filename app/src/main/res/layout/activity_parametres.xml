<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <TextView
        android:id="@+id/titreParametres"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titre_parametres"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#F0EAD6"
        android:fontFamily="sans-serif"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/separateurParametres"
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="#4A90E2"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/titreParametres"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ligne Vibration -->
    <TextView
        android:id="@+id/labelVibrationTitre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/param_vibration_titre"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#F0EAD6"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/separateurParametres"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switchVibration"/>

    <TextView
        android:id="@+id/labelVibrationDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/param_vibration_desc"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/labelVibrationTitre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switchVibration"/>

    <Switch
        android:id="@+id/switchVibration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumbTint="#4A90E2"
        android:trackTint="#2E3D52"
        app:layout_constraintTop_toTopOf="@id/labelVibrationTitre"
        app:layout_constraintBottom_toBottomOf="@id/labelVibrationDesc"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Séparateur léger -->
    <View
        android:id="@+id/separateurLigne1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#1E2A3A"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/labelVibrationDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ligne Capteur -->
    <TextView
        android:id="@+id/labelCapteurTitre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/param_capteur_titre"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#F0EAD6"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/separateurLigne1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switchCapteur"/>

    <TextView
        android:id="@+id/labelCapteurDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/param_capteur_desc"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/labelCapteurTitre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switchCapteur"/>

    <Switch
        android:id="@+id/switchCapteur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumbTint="#4A90E2"
        android:trackTint="#2E3D52"
        app:layout_constraintTop_toTopOf="@id/labelCapteurTitre"
        app:layout_constraintBottom_toBottomOf="@id/labelCapteurDesc"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/boutonRetourParametres"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:text="@string/bouton_retour_parametres"
        android:textColor="#F0EAD6"
        android:backgroundTint="#1E2A3A"
        android:stateListAnimator="@null"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
