<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fond"
    tools:context=".LabyrintheActivity">

    <TextView
        android:id="@+id/titreLabyrinthe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titreJeu"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="@color/texte"
        android:letterSpacing="0.08"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/sousTitre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sous_titre"
        android:textSize="14sp"
        android:textColor="@color/texteFonce"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/titreLabyrinthe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/separateur"
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="@color/accent"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/sousTitre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:id="@+id/scrollNiveaux"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/separateur"
        app:layout_constraintBottom_toTopOf="@id/boutonParametres"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/conteneurNiveaux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

    </ScrollView>

    <Button
        android:id="@+id/boutonParametres"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="@string/bouton_parametres"
        android:textSize="14sp"
        android:textColor="@color/texteSecondaire"
        android:backgroundTint="@color/bordure"
        android:stateListAnimator="@null"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/scrollNiveaux"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/boutonQuitter"/>

    <Button
        android:id="@+id/boutonQuitter"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="@string/bouton_quitter"
        android:textSize="14sp"
        android:textColor="@color/danger"
        android:backgroundTint="@color/bordure"
        android:stateListAnimator="@null"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/boutonParametres"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
