<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    tools:context=".labyrinthe.view.JeuLabyrintheActivity">

    <!-- Vue labyrinthe plein écran -->
    <com.example.joestarapp.labyrinthe.view.VueLabyrinthe
        android:id="@+id/vueLabyrinthe"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- HUD en haut -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#CC0D1117"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/texteNiveau"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/hud_niveau"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#4A90E2"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/texteTemps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hud_temps"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F0EAD6"
            android:fontFamily="monospace"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/texteScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/hud_score"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:gravity="end"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- Boutons en bas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="8dp"
        android:background="#CC0D1117">

        <!-- Bouton Retour (gauche) -->
        <Button
            android:id="@+id/boutonRetour"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/bouton_retour"
            android:textSize="13sp"
            android:textColor="#E05252"
            android:backgroundTint="#CC1E2A3A"
            android:stateListAnimator="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

        <!-- Espace flexible entre les deux boutons -->
        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <!-- Bouton Pause (droite) -->
        <Button
            android:id="@+id/boutonPause"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/bouton_pause"
            android:textSize="13sp"
            android:textColor="#F0EAD6"
            android:backgroundTint="#CC1E2A3A"
            android:stateListAnimator="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

    </LinearLayout>

</FrameLayout>
